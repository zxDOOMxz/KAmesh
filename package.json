    "build:ios": "eas build --platform ios --profile production",
    "rustore:apk": "eas build --platform android --profile rustore-apk",
    "rustore:aab": "eas build --platform android --profile rustore-aab",
    "rustore:submit": "eas submit --platform android --profile rustore",
    "rustore:keystore": "create-keystore.bat",
    "rustore:build": "build-rustore.bat"
